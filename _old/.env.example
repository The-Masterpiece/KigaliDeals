# Copy this file to .env.local and fill in your real values
# NEVER commit .env.local to git

# Supabase - get from Supabase Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Anthropic - get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Cron Secret - make up any long random string, used to protect the cron endpoint
CRON_SECRET=make-up-a-random-long-string-here

# MTN MoMo (coming in Phase 3)
MOMO_API_KEY=
MOMO_API_USER=
MOMO_SUBSCRIPTION_KEY=
MOMO_ENVIRONMENT=sandbox

# Twilio WhatsApp (coming in Phase 3)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
